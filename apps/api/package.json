{
  "name": "@aide/api",
  "version": "0.1.0",
  "private": true,
  "description": "AIDE backend — Express API foundation",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/server.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node --env-file-if-exists=.env dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aide/shared-types": "*",
    "@anthropic-ai/sdk": "^0.32.0",
    "@google/genai": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "libphonenumber-js": "^1.11.0",
    "multer": "^2.0.1",
    "openai": "^4.80.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.0",
    "tsc-alias": "^1.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
