{
  "name": "@aide/api",
  "version": "0.1.0",
  "private": true,
  "description": "AIDE backend — Express API foundation",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node --env-file-if-exists=.env dist/server.js"
  },
  "dependencies": {
    "@aide/shared-types": "*",
    "cors": "^2.8.5",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.15.0",
    "tsc-alias": "^1.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
