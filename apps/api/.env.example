PORT=4000
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# AI Orchestration Platform — defaults to the Mock provider if left unset,
# so no key is needed to run or test the app. Set AI_PROVIDER to switch to a
# real provider; its matching API key becomes required (fails fast if missing).
AI_PROVIDER=mock
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# AI_PROVIDER=gemini
# GEMINI_API_KEY=
# AI_PROVIDER=claude
# CLAUDE_API_KEY=
# AI_MODEL=
# AI_TEMPERATURE=0.2
# AI_MAX_TOKENS=4096
# AI_TIMEOUT_MS=45000
